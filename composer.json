{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "jeffersongoncalves/nativekitv5",
    "type": "project",
    "description": "NativeKit starter kit built on Laravel 13.x, Filament 5.x and NativePHP for native desktop applications.",
    "keywords": [
        "laravel-starter-kit",
        "starter-kit",
        "filament-starter-kit",
        "nativephp-starter-kit",
        "laravel",
        "filament",
        "filament-v5",
        "livewire",
        "tailwindcss",
        "nativephp",
        "desktop-app",
        "electron"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "dutchcodingcompany/filament-developer-logins": "^2.1",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0.0",
        "livewire/livewire": "^4.0",
        "nativephp/electron": "^1.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.0",
        "barryvdh/laravel-ide-helper": "^3.5",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.2",
        "laravel/pail": "^1.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan icons:cache"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --tag=livewire:assets --ansi --force",
            "@php artisan filament:upgrade"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "ide-helper": [
            "@php artisan ide-helper:generate -q",
            "@php artisan ide-helper:meta -q",
            "@php artisan ide-helper:model --write --reset -q -n",
            "./vendor/bin/pint --config=pint.json -q"
        ],
        "pint": [
            "./vendor/bin/pint --config=pint.json -q"
        ],
        "phpstan": [
            "./vendor/bin/phpstan"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "schedule": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd\" \"php artisan schedule:work\" --names=schedule"
        ],
        "queue": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd\" \"php artisan queue:listen --tries=1\" --names=queue"
        ],
        "native:dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -k -c \"#93c5fd,#c4b5fd\" \"php artisan native:serve --no-interaction\" \"npm run dev\" --names=app,vite"
        ]
    },
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "nativephp/laravel",
                "version": "1.3.99",
                "type": "library",
                "homepage": "https://github.com/nativephp/laravel",
                "license": "MIT",
                "source": {
                    "url": "https://github.com/NativePHP/laravel",
                    "type": "git",
                    "reference": "1.3.1"
                },
                "require": {
                    "php": "^8.3",
                    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
                    "spatie/laravel-package-tools": "^1.16.4",
                    "symfony/finder": "^6.2|^7.0"
                },
                "autoload": {
                    "psr-4": {
                        "Native\\Laravel\\": "src/"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "Native\\Laravel\\NativeServiceProvider"
                        ],
                        "aliases": {
                            "ChildProcess": "Native\\Laravel\\Facades\\ChildProcess",
                            "Clipboard": "Native\\Laravel\\Facades\\Clipboard",
                            "ContextMenu": "Native\\Laravel\\Facades\\ContextMenu",
                            "Dock": "Native\\Laravel\\Facades\\Dock",
                            "GlobalShortcut": "Native\\Laravel\\Facades\\GlobalShortcut",
                            "Menu": "Native\\Laravel\\Facades\\Menu",
                            "MenuBar": "Native\\Laravel\\Facades\\MenuBar",
                            "Notification": "Native\\Laravel\\Facades\\Notification",
                            "PowerMonitor": "Native\\Laravel\\Facades\\PowerMonitor",
                            "Process": "Native\\Laravel\\Facades\\Process",
                            "QueueWorker": "Native\\Laravel\\Facades\\QueueWorker",
                            "Screen": "Native\\Laravel\\Facades\\Screen",
                            "Settings": "Native\\Laravel\\Facades\\Settings",
                            "Shell": "Native\\Laravel\\Facades\\Shell",
                            "System": "Native\\Laravel\\Facades\\System",
                            "Window": "Native\\Laravel\\Facades\\Window"
                        }
                    }
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "nativephp/electron",
                "version": "1.3.99",
                "type": "library",
                "homepage": "https://github.com/nativephp/electron",
                "license": "MIT",
                "source": {
                    "url": "https://github.com/NativePHP/electron",
                    "type": "git",
                    "reference": "1.3.0"
                },
                "require": {
                    "php": "^8.3",
                    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
                    "laravel/prompts": "^0.1.1|^0.2|^0.3",
                    "nativephp/laravel": "^1.0",
                    "nativephp/php-bin": "^1.0",
                    "spatie/laravel-package-tools": "^1.16.4",
                    "symfony/filesystem": "^6.4|^7.2",
                    "ext-zip": "*"
                },
                "autoload": {
                    "psr-4": {
                        "Native\\Electron\\": "src/"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "Native\\Electron\\ElectronServiceProvider"
                        ],
                        "aliases": {
                            "Updater": "Native\\Electron\\Facades\\Updater"
                        }
                    }
                }
            }
        }
    ],
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "ext-pcntl": "7.1",
            "ext-posix": "7.1"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
